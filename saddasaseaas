                Custom:Create("TextLabel", {
                    Font = Custom.Font,
                    Text = Title,
                    TextColor3 = Color3.fromRGB(230, 230, 230),
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextYAlignment = Enum.TextYAlignment.Top,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 6),
                    Size = UDim2.new(1, -180, 0, 13),
                    Name = "SliderTitle",
                }, Slider)

                local SliderContent = Custom:Create("TextLabel", {
                    Font = Custom.FontBody,
                    Text = Content,
                    TextColor3 = Color3.fromRGB(255, 255, 255),
                    TextTransparency = 0.4,
                    TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextYAlignment = Enum.TextYAlignment.Bottom,
                    TextWrapped = true,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 19),
                    Size = UDim2.new(1, -180, 0, 12),
                    Name = "SliderContent",
                }, Slider)

                local SliderInput = Custom:Create("Frame", {
                    AnchorPoint = Vector2.new(0, 0.5),
                    BackgroundColor3 = Custom.ColorRGB,
                    Position = UDim2.new(1, -155, 0.5, 0),
                    Size = UDim2.new(0, 26, 0, 18),
                    Name = "SliderInput",
                }, Slider)

                Custom:Create("UICorner", {CornerRadius = UDim.new(0, 3)}, SliderInput)

                local TextBox = Custom:Create("TextBox", {
                    Font = Custom.Font,
                    Text = tostring(Default),
                    TextColor3 = Color3.fromRGB(255, 255, 255),
                    TextSize = 11,
                    TextWrapped = true,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                }, SliderInput)

                local SliderFrame = Custom:Create("Frame", {
                    AnchorPoint = Vector2.new(1, 0.5),
                    BackgroundColor3 = Color3.fromRGB(60, 60, 65),
                    Position = UDim2.new(1, -20, 0.5, 0),
                    Size = UDim2.new(0, 100, 0, 4),
                    Name = "SliderFrame",
                }, Slider)

                Custom:Create("UICorner", {CornerRadius = UDim.new(0, 2)}, SliderFrame)

                local SliderDraggable = Custom:Create("Frame", {
                    BackgroundColor3 = Custom.ColorRGB,
                    Size = UDim2.new((Default - Min) / (Max - Min), 0, 0, 4),
                    Name = "SliderDraggable",
                }, SliderFrame)

                Custom:Create("UICorner", {CornerRadius = UDim.new(0, 2)}, SliderDraggable)

                local SliderCircle = Custom:Create("Frame", {
                    BackgroundColor3 = Custom.ColorRGB,
                    Position = UDim2.new(1, 0, 0.5, 0),
                    Size = UDim2.new(0, 10, 0, 10),
                    Name = "SliderCircle",
                }, SliderDraggable)

                Custom:Create("UICorner", {CornerRadius = UDim.new(0, 5)}, SliderCircle)
                Custom:Create("UIStroke", {Color = Custom.ColorRGB, Thickness = 0}, SliderCircle)

                local Dragging = false
                local moveConn = nil

                local function Round(Number, Factor)
                    local Result = math.floor(Number / Factor + (math.sign(Number) * 0.5)) * Factor
                    if Result < 0 then Result = Result + Factor end
                    return Result
                end

                function Funcs_Slider:Set(Value)
                    Value = math.clamp(Round(Value, Increment), Min, Max)
                    Funcs_Slider.Value = Value
                    TextBox.Text = tostring(Value)
                    local scale = (Value - Min) / (Max - Min)
                    TweenService:Create(SliderDraggable, TweenInfo.new(0.1), {Size = UDim2.new(scale, 0, 0, 1)}):Play()
                end

                SliderFrame.InputBegan:Connect(function(Input)
                    if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                        Dragging = true
                        if not moveConn then
                            moveConn = UserInputService.InputChanged:Connect(function(MoveInput)
                                if Dragging and (MoveInput.UserInputType == Enum.UserInputType.MouseMovement or MoveInput.UserInputType == Enum.UserInputType.Touch) then
                                    local SizeScale = math.clamp((MoveInput.Position.X - SliderFrame.AbsolutePosition.X) / SliderFrame.AbsoluteSize.X, 0, 1)
                                    Funcs_Slider:Set(Min + ((Max - Min) * SizeScale))
                                end
                            end)
                        end
                    end
                end)

                SliderFrame.InputEnded:Connect(function(Input)
                    if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                        Dragging = false
                        if moveConn then
                            moveConn:Disconnect()
                            moveConn = nil
                        end
                        Callback(Funcs_Slider.Value)
                    end
                end)

                TextBox.FocusLost:Connect(function()
                    local Valid = tonumber(TextBox.Text:gsub("[^%d]", "")) or 0
                    Funcs_Slider:Set(Valid)
                    Callback(Funcs_Slider.Value)
                end)

                Funcs_Slider:Set(Default)
                Callback(Default)
                ItemCount = ItemCount + 1
                return Funcs_Slider
            end

            function Item:AddInput(Config)
                local Title = Config[1] or Config.Title or ""
                local Content = Config[2] or Config.Content or ""
                local Default = Config[3] or Config.Default or ""
                local Callback = Config[4] or Config.Callback or function() end

                local Funcs_Input = {Value = Default}

                local Input = Custom:Create("Frame", {
                    BackgroundColor3 = Color3.fromRGB(35, 32, 46),
                    LayoutOrder = ItemCount,
                    Size = UDim2.new(1, 0, 0, 32),
                    Name = "Input",
                }, SectionAdd)

                Custom:Create("UICorner", {CornerRadius = UDim.new(0, 4)}, Input)

                Custom:Create("TextLabel", {
                    Font = Custom.Font,
                    Text = Title,
                    TextColor3 = Color3.fromRGB(230, 230, 230),
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextYAlignment = Enum.TextYAlignment.Top,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 6),
                    Size = UDim2.new(1, -180, 0, 13),
                    Name = "InputTitle",
                }, Input)

                local InputContent = Custom:Create("TextLabel", {
                    Font = Custom.FontBody,
                    Text = Content,
                    TextColor3 = Color3.fromRGB(255, 255, 255),
                    TextTransparency = 0.4,
                    TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextYAlignment = Enum.TextYAlignment.Bottom,
                    TextWrapped = true,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 19),
                    Size = UDim2.new(1, -180, 0, 12),
                    Name = "InputContent",
                }, Input)

                InputContent:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
                    local newHeight = math.max(32, InputContent.AbsoluteSize.Y + 22)
                    Input.Size = UDim2.new(1, 0, 0, newHeight)
                    UpdateSizeSection()
                end)

                local InputFrame = Custom:Create("Frame", {
                    AnchorPoint = Vector2.new(1, 0.5),
                    BackgroundColor3 = Color3.fromRGB(45, 42, 56),
                    ClipsDescendants = true,
                    Position = UDim2.new(1, -7, 0.5, 0),
                    Size = UDim2.new(0, 148, 0, 26),
                    Name = "InputFrame"
                }, Input)

                Custom:Create("UICorner", {CornerRadius = UDim.new(0, 4)}, InputFrame)

                local InputTextBox = Custom:Create("TextBox", {
                    Font = Custom.Font,
                    PlaceholderText = "Write your input there",
                    PlaceholderColor3 = Color3.fromRGB(120, 120, 120),
                    Text = "",
                    TextColor3 = Color3.fromRGB(255, 255, 255),
                    TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 5, 0.5, 0),
                    Size = UDim2.new(1, -10, 1, 0),
                    Name = "InputTextBox"
                }, InputFrame)

                function Funcs_Input:Set(Value)
                    InputTextBox.Text = Value
                    Funcs_Input.Value = Value
                    Callback(Value)
                end

                InputTextBox.FocusLost:Connect(function()
                    Funcs_Input:Set(InputTextBox.Text)
                end)

                Funcs_Input:Set(Default)
                ItemCount = ItemCount + 1
                return Funcs_Input
            end

            function Item:AddDropdown(Config)
                local Title = Config[1] or Config.Title or ""
                local Content = Config[2] or Config.Content or ""
                local Multi = Config[3] or Config.Multi or false
                local Options = Config[4] or Config.Options or {}
                local Default = Config[5] or Config.Default or {}
                local Callback = Config[6] or Config.Callback or function() end

                local Funcs_Dropdown = {Value = Default, Options = Options}

                local Dropdown = Custom:Create("Frame", {
                    BackgroundColor3 = Color3.fromRGB(35, 32, 46),
                    LayoutOrder = ItemCount,
                    Size = UDim2.new(1, 0, 0, 32),
                    Name = "Dropdown"
                }, SectionAdd)

                Custom:Create("UICorner", {CornerRadius = UDim.new(0, 4)}, Dropdown)

                local DropdownButton = Custom:Create("TextButton", {
                    Font = Custom.Font,
                    Text = "",
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Name = "ToggleButton"
                }, Dropdown)

                Custom:Create("TextLabel", {
                    Font = Custom.Font,
                    Text = Title,
                    TextColor3 = Color3.fromRGB(230, 230, 230),
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextYAlignment = Enum.TextYAlignment.Top,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 6),
                    Size = UDim2.new(1, -180, 0, 13),
                    Name = "DropdownTitle",
                }, Dropdown)

                local DropdownContent = Custom:Create("TextLabel", {
                    Font = Custom.FontBody,
                    Text = Content,
                    TextColor3 = Color3.fromRGB(255, 255, 255),
                    TextTransparency = 0.4,
                    TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextYAlignment = Enum.TextYAlignment.Bottom,
                    TextWrapped = true,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 19),
                    Size = UDim2.new(1, -180, 0, 12),
                    Name = "DropdownContent",
                }, Dropdown)

                DropdownContent:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
                    local newHeight = math.max(32, DropdownContent.AbsoluteSize.Y + 22)
                    Dropdown.Size = UDim2.new(1, 0, 0, newHeight)
                    UpdateSizeSection()
                end)

                -- Dropdown selector (simplified - just shows current selection)
                local SelectOptionsFrame = Custom:Create("Frame", {
                    BackgroundColor3 = Color3.fromRGB(45, 42, 56),
                    Position = UDim2.new(1, -7, 0.5, 0),
                    Size = UDim2.new(0, 148, 0, 26),
                    Name = "SelectOptionsFrame",
                }, Dropdown)

                Custom:Create("UICorner", {CornerRadius = UDim.new(0, 4)}, SelectOptionsFrame)

                local OptionSelecting = Custom:Create("TextLabel", {
                    Font = Custom.Font,
                    Text = "Select...",
                    TextColor3 = Color3.fromRGB(255, 255, 255),
                    TextTransparency = 0.4,
                    TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 8, 0.5, 0),
                    Size = UDim2.new(1, -30, 1, 0),
                    Name = "OptionSelecting",
                }, SelectOptionsFrame)

                local OptionImg = Custom:Create("ImageLabel", {
                    Image = "rbxassetid://90200523188815",
                    BackgroundTransparency = 1,
                    AnchorPoint = Vector2.new(1, 0.5),
                    Position = UDim2.new(1, -5, 0.5, 0),
                    Size = UDim2.new(0, 16, 0, 16),
                    Name = "OptionImg",
                }, SelectOptionsFrame)

                -- Options popup
                local DropdownPopup = nil
                local popupOpen = false

                local function CreateDropdownPopup()
                    if DropdownPopup then DropdownPopup:Destroy() end

                    popupOpen = true
                    DropdownPopup = Custom:Create("Frame", {
                        BackgroundColor3 = Color3.fromRGB(25, 22, 35),
                        Position = UDim2.new(0, 0, 1, 5),
                        Size = UDim2.new(1, 0, 0, 0),
                        ClipsDescendants = true,
                        ZIndex = 100,
                        Name = "DropdownPopup"
                    }, Dropdown)

                    Custom:Create("UICorner", {CornerRadius = UDim.new(0, 6)}, DropdownPopup)
                    Custom:Create("UIStroke", {Color = Custom.ColorRGB, Thickness = 1, Transparency = 0.5}, DropdownPopup)

                    local popupScroll = Custom:Create("ScrollingFrame", {
                        CanvasSize = UDim2.new(0, 0, 0, 0),
                        ScrollBarImageColor3 = Custom.ColorRGB,
                        ScrollBarThickness = 2,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 1, 0),
                        Name = "PopupScroll"
                    }, DropdownPopup)

                    Custom:Create("UIListLayout", {
                        Padding = UDim.new(0, 2),
                        SortOrder = Enum.SortOrder.LayoutOrder
                    }, popupScroll)

                    local totalHeight = 0
                    for _, optName in ipairs(Funcs_Dropdown.Options) do
                        local isSelected = table.find(Funcs_Dropdown.Value, optName) ~= nil

                        local optBtn = Custom:Create("Frame", {
                            BackgroundColor3 = isSelected and Color3.fromRGB(45, 42, 56) or Color3.fromRGB(35, 32, 46),
                            Size = UDim2.new(1, 0, 0, 26),
                            Name = "Option"
                        }, popupScroll)

                        Custom:Create("UICorner", {CornerRadius = UDim.new(0, 4)}, optBtn)

                        if isSelected then
                            local checkmark = Custom:Create("Frame", {
                                BackgroundColor3 = Custom.ColorRGB,
                                Position = UDim2.new(0, 4, 0.5, 0),
                                Size = UDim2.new(0, 4, 0, 12),
                                Name = "Checkmark"
                            }, optBtn)
                            Custom:Create("UICorner", {}, checkmark)
                        end

                        Custom:Create("TextLabel", {
                            Font = Custom.Font,
                            Text = optName,
                            TextColor3 = Color3.fromRGB(235, 235, 240),
                            TextSize = 12,
                            TextXAlignment = Enum.TextXAlignment.Left,
                            BackgroundTransparency = 1,
                            Position = UDim2.new(0, isSelected and 14 or 8, 0, 0),
                            Size = UDim2.new(1, -16, 1, 0),
                            Name = "OptionText"
                        }, optBtn)

                        optBtn.InputBegan:Connect(function(input)
                            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                                CircleClick(optBtn, Player:GetMouse().X, Player:GetMouse().Y)

                                if Multi then
                                    if isSelected then
                                        for i, v in ipairs(Funcs_Dropdown.Value) do
                                            if v == optName then table.remove(Funcs_Dropdown.Value, i) break end
                                        end
                                    else
                                        table.insert(Funcs_Dropdown.Value, optName)
                                    end
                                else
                                    Funcs_Dropdown.Value = {optName}
                                end

                                Funcs_Dropdown:Set(Funcs_Dropdown.Value)
                                CreateDropdownPopup()
                            end
                        end)

                        totalHeight = totalHeight + 28
                    end

                    popupScroll.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
                    DropdownPopup.Size = UDim2.new(1, 0, 0, math.min(totalHeight, 150))

                    -- Click outside to close
                    local closeConn = nil
                    closeConn = UserInputService.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            local mouse = Player:GetMouse()
                            local pos = mouse.Y
                            if pos < DropdownPopup.AbsolutePosition.Y or pos > DropdownPopup.AbsolutePosition.Y + DropdownPopup.AbsoluteSize.Y then
                                popupOpen = false
                                closeConn:Disconnect()
                                if DropdownPopup then DropdownPopup:Destroy() end
                            end
                        end
                    end)
                end

                DropdownButton.Activated:Connect(function()
                    CircleClick(DropdownButton, Player:GetMouse().X, Player:GetMouse().Y)
                    if popupOpen then
                        popupOpen = false
                        if DropdownPopup then DropdownPopup:Destroy() end
                    else
                        CreateDropdownPopup()
                    end
                end)

                function Funcs_Dropdown:Set(Value)
                    Funcs_Dropdown.Value = Value or Funcs_Dropdown.Value
                    local displayText = table.concat(Funcs_Dropdown.Value, ", ")
                    OptionSelecting.Text = displayText ~= "" and displayText or "Select..."
                    Callback(Funcs_Dropdown.Value)
                end

                function Funcs_Dropdown:Refresh(RefreshList, Selecting)
                    RefreshList = RefreshList or {}
                    Selecting = Selecting or {}
                    Funcs_Dropdown.Options = RefreshList
                    Funcs_Dropdown.Value = Selecting
                    Funcs_Dropdown:Set(Funcs_Dropdown.Value)
                end

                Funcs_Dropdown:Refresh(Funcs_Dropdown.Options, Funcs_Dropdown.Value)
                ItemCount = ItemCount + 1
                return Funcs_Dropdown
            end

            ItemCount = ItemCount + 1
            return Item
        end

        CountTab = CountTab + 1
        return Sections
    end

    return Tabs
end

return WisHub_Library
