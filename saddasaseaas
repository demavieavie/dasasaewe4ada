    local SearchIndex = 0
    local function UpdateSearchResults(results)
        -- Clear old results
        for _, child in pairs(SearchScroll:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end

        if #results == 0 then
            SearchResults.Size = UDim2.new(1, 0, 0, 0)
            return
        end

        local y = 0
        for i, result in ipairs(results) do
            local resultBtn = Custom:Create("Frame", {
                BackgroundColor3 = i == 1 and Color3.fromRGB(45, 42, 56) or Color3.fromRGB(35, 32, 46),
                Size = UDim2.new(1, 0, 0, 28),
                LayoutOrder = i,
                Name = "Result"
            }, SearchScroll)

            Custom:Create("UICorner", {CornerRadius = UDim.new(0, 4)}, resultBtn)

            local icon = Custom:Create("ImageLabel", {
                Image = result.icon or "",
                ImageColor3 = Custom.ColorRGB,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 8, 0.5, 0),
                Size = UDim2.new(0, 14, 0, 14),
                Name = "Icon"
            }, resultBtn)

            local resultText = Custom:Create("TextLabel", {
                Font = Custom.Font,
                Text = result.tabName .. " > " .. result.sectionName,
                TextColor3 = Color3.fromRGB(235, 235, 240),
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 28, 0, 0),
                Size = UDim2.new(1, -40, 0, 14),
                Name = "ResultText"
            }, resultBtn)

            local typeText = Custom:Create("TextLabel", {
                Font = Custom.FontBody,
                Text = result.type,
                TextColor3 = Color3.fromRGB(150, 150, 160),
                TextSize = 10,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 28, 0, 16),
                Size = UDim2.new(1, -40, 0, 10),
                Name = "TypeText"
            }, resultBtn)

            resultBtn.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    CircleClick(resultBtn, Player:GetMouse().X, Player:GetMouse().Y)
                    result.callback()
                    SearchBox.Text = ""
                    SearchResults.Visible = false
                    ClearSearch.Visible = false
                end
            end)

            y = y + 30
        end

        SearchScroll.CanvasSize = UDim2.new(0, 0, 0, y)
        SearchResults.Size = UDim2.new(1, 0, 0, math.min(y, 150))
    end

    -- Fuzzy search function
    local function fuzzyMatch(query, text)
        query = string.lower(query)
        text = string.lower(text)

        -- Exact match
        if string.find(text, query, 1, true) then
            return true, string.find(text, query, 1, true)
        end

        -- Fuzzy: check if all chars exist in order
        local queryIdx = 1
        for i = 1, #text do
            if queryIdx <= #query and string.sub(text, i, i) == string.sub(query, queryIdx, queryIdx) then
                queryIdx = queryIdx + 1
            end
        end

        return queryIdx > #query, -1
    end

    -- Tab storage for search
    local allTabs = {}
    local allSections = {}

    -- Enhanced search with debounce
    local pendingSearch = nil

    SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
        ClearSearch.Visible = #SearchBox.Text > 0

        if #SearchBox.Text == 0 then
            SearchResults.Visible = false
            -- Restore all tabs
            for _, tabData in ipairs(allTabs) do
                tabData.frame.Visible = true
                tabData.highlighted = false
            end
            return
        end

        SearchResults.Visible = true
        local query = SearchBox.Text

        -- Debounce search
        if pendingSearch then task.cancel(pendingSearch) end
        pendingSearch = task.defer(function()
            local results = {}

            for tabIdx, tabData in ipairs(allTabs) do
                local tabName = tabData.name
                local tabMatch, tabPos = fuzzyMatch(query, tabName)

                -- Check sections in this tab
                for secIdx, secData in ipairs(tabData.sections or {}) do
                    local secName = secData.name
                    local secMatch, secPos = fuzzyMatch(query, secName)
                    local tabMatch2, _ = fuzzyMatch(query, tabName)

                    if secMatch or tabMatch2 then
                        table.insert(results, {
                            tabName = tabName,
                            sectionName = secName,
                            tabIndex = tabIdx,
                            sectionIndex = secIdx,
                            icon = tabData.icon,
                            type = secMatch and "Section" or "Tab",
                            callback = function()
                                -- Switch to tab
                                if LayersPageLayout.CurrentPage ~= tabData.page then
                                    LayersPageLayout:JumpToIndex(tabIdx - 1)
                                    NameTab.Text = tabName
                                end
                                -- Open section
                                if secData.toggleFunc then
                                    secData.toggleFunc()
                                end
                                -- Scroll to section
                                if tabData.page then
                                    local canvas = tabData.page:FindFirstChild("ScrolLayers")
                                    if canvas then
                                        local secFrame = canvas:FindFirstChild(secData.name)
                                        if secFrame then
                                            local targetY = secFrame.Position.Y.Offset - 50
                                            TweenService:Create(canvas, TweenInfo.new(0.3), {CanvasPosition = Vector2.new(0, math.max(0, targetY))}):Play()
                                        end
                                    end
                                end
                            end
                        })
                    end
                end

                -- Tab match (if not already in results)
                if tabMatch and #results == 0 then
                    table.insert(results, 1, {
                        tabName = tabName,
                        sectionName = "",
                        tabIndex = tabIdx,
                        sectionIndex = -1,
                        icon = tabData.icon,
                        type = "Tab",
