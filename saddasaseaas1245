    -- Enhanced search with debounce
    local pendingSearch = nil

    SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
        ClearSearch.Visible = #SearchBox.Text > 0

        if #SearchBox.Text == 0 then
            SearchResults.Visible = false
            -- Restore all tabs
            for _, tabData in ipairs(allTabs) do
                tabData.frame.Visible = true
                tabData.highlighted = false
            end
            return
        end

        SearchResults.Visible = true
        local query = SearchBox.Text

        -- Debounce search
        if pendingSearch then task.cancel(pendingSearch) end
        pendingSearch = task.defer(function()
            local results = {}

            for tabIdx, tabData in ipairs(allTabs) do
                local tabName = tabData.name
                local tabMatch, tabPos = fuzzyMatch(query, tabName)

                -- Check sections in this tab
                for secIdx, secData in ipairs(tabData.sections or {}) do
                    local secName = secData.name
                    local secMatch, secPos = fuzzyMatch(query, secName)
                    local tabMatch2, _ = fuzzyMatch(query, tabName)

                    if secMatch or tabMatch2 then
                        table.insert(results, {
                            tabName = tabName,
                            sectionName = secName,
                            tabIndex = tabIdx,
                            sectionIndex = secIdx,
                            icon = tabData.icon,
                            type = secMatch and "Section" or "Tab",
                            callback = function()
                                -- Switch to tab
                                if LayersPageLayout.CurrentPage ~= tabData.page then
                                    LayersPageLayout:JumpToIndex(tabIdx - 1)
                                    NameTab.Text = tabName
                                    PlayTabSwitch()
                                end
                                -- Open section
                                if secData.toggleFunc then
                                    secData.toggleFunc()
                                end
                                -- Scroll to section
                                if tabData.page then
                                    local canvas = tabData.page:FindFirstChild("ScrolLayers")
                                    if canvas then
                                        local secFrame = canvas:FindFirstChild(secData.name)
                                        if secFrame then
                                            local targetY = secFrame.Position.Y.Offset - 50
                                            TweenService:Create(canvas, TweenInfo.new(0.3), {CanvasPosition = Vector2.new(0, math.max(0, targetY))}):Play()
                                        end
                                    end
                                end
                            end
                        })
                    end
                end

                -- Tab match (if not already in results)
                if tabMatch and #results == 0 then
                    table.insert(results, 1, {
                        tabName = tabName,
                        sectionName = "",
                        tabIndex = tabIdx,
                        sectionIndex = -1,
                        icon = tabData.icon,
                        type = "Tab",
                        callback = function()
                            LayersPageLayout:JumpToIndex(tabIdx - 1)
                            NameTab.Text = tabName
                            PlayTabSwitch()
                            SearchBox.Text = ""
                            SearchResults.Visible = false
                        end
                    })
                end
            end

            UpdateSearchResults(results)
        end)
    end)

