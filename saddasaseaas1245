        TextDesc = Custom.Muted,
        TextMuted = Color3.fromRGB(124, 122, 140),
        Purple = Custom.ColorRGB,
    }

    local TabGap = 4
    local SectionGap = 5
    local ItemGap = 5

    local ConfigVersion = Config.Version or 1
    local ConfigElements = {}

    local function CleanFileName(name)
        name = tostring(name or "")
        name = name:gsub("^%s+", ""):gsub("%s+$", "")
        name = name:gsub("[^%w_%- ]", "_")
        name = name:gsub("%s+", "_")
        return name
    end

    local function GetGameConfigName()
        local gameName = Config.ConfigName or Config.GameName
        if not gameName or gameName == "" then
            local ok, info = pcall(function()
                return MarketplaceService:GetProductInfo(game.PlaceId)
            end)
            gameName = ok and info and info.Name or tostring(game.PlaceId)
        end
        return CleanFileName(gameName)
    end

    local ConfigRoot = Config.ConfigRoot or "WisHUB_UI_Settings"
    local ConfigFolder = ConfigRoot .. "/Configs"
    local GameConfigFolder = ConfigFolder .. "/" .. GetGameConfigName()
    local AutoLoadFile = GameConfigFolder .. "/_autoload.json"

    local function HasFileApi()
        return isfolder and makefolder and isfile and readfile and writefile
    end

    local function EnsureFolder(path)
        if isfolder and makefolder and not isfolder(path) then
            makefolder(path)
        end
    end

    local function EnsureConfigFolder()
        if not HasFileApi() then return false end
        EnsureFolder(ConfigRoot)
        EnsureFolder(ConfigFolder)
        EnsureFolder(GameConfigFolder)
        return true
    end

    local function GetConfigPath(name)
        return GameConfigFolder .. "/" .. CleanFileName(name) .. ".json"
    end

    local function NotifyConfig(message, isError)
        WisHub_Library:SetNotification({
            Title = "WisHUB",
            Description = "Config",
            Content = message,
            Time = 0.35,
            Delay = isError and 3 or 2
        })
    end

    local function ShouldUseConfig(cfg)
        return cfg.NoConfig ~= true and cfg.Config ~= false
    end

    local function RegisterConfigElement(kind, title, cfg, element)
        if not ShouldUseConfig(cfg) then return end
        local key = cfg.ConfigKey or cfg.Key or (kind .. "_" .. CleanFileName(title))
        ConfigElements[key] = element
    end

    local function BuildConfigData()
        local data = {_version = ConfigVersion}
        for key, element in pairs(ConfigElements) do
            if element.Get then
                data[key] = element:Get()
            else
                data[key] = element.Value
            end
        end
        return data
    end

    local function ReadConfigPayload(name)
        if not HasFileApi() then return nil end
        local path = GetConfigPath(name)
        if not isfile(path) then return nil end
        local ok, decoded = pcall(function()
            return HttpService:JSONDecode(readfile(path))
        end)
        if not ok or type(decoded) ~= "table" then return nil end
        return decoded.Data or decoded
    end

    local function SaveConfigAs(name)
        local cleanName = CleanFileName(name)
        if cleanName == "" then
            NotifyConfig("Enter a config name first", true)
            return false
        end
        if not EnsureConfigFolder() then
            NotifyConfig("File API unavailable", true)
            return false
        end
        local ok = pcall(function()
            writefile(GetConfigPath(cleanName), HttpService:JSONEncode(BuildConfigData()))
        end)
        if ok then
            NotifyConfig("Saved '" .. cleanName .. "'")
            return true, cleanName
        end
        NotifyConfig("Failed to save config", true)
        return false
    end

    local function LoadConfigByName(name)
        local cleanName = CleanFileName(name)
        if cleanName == "" then
            NotifyConfig("Choose a config first", true)
            return false
        end
        local data = ReadConfigPayload(cleanName)
        if not data then
            NotifyConfig("Config '" .. cleanName .. "' not found", true)
            return false
        end
        for key, value in pairs(data) do
            local element = ConfigElements[key]
            if element and element.Set then
                element:Set(value)
                if element.__ConfigCallback then
                    element.__ConfigCallback(element.Value)
                end
            end
        end
        NotifyConfig("Loaded '" .. cleanName .. "'")
        return true
    end

    local function GetConfigs()
        if not EnsureConfigFolder() or not listfiles then return {} end
        local ok, files = pcall(function()
            return listfiles(GameConfigFolder)
        end)
        if not ok or type(files) ~= "table" then return {} end

        local configs = {}
        for _, path in ipairs(files) do
            local normalizedPath = tostring(path):gsub("\\", "/")
            local fileName = normalizedPath:match("[^/]+$") or normalizedPath
            local configName = fileName:match("(.+)%.json$")
            if configName and configName ~= "_autoload" then
                table.insert(configs, configName)
            end
        end
        table.sort(configs)
        return configs
    end

    local function SetAutoLoad(name, enabled)
        local cleanName = CleanFileName(name)
        if not EnsureConfigFolder() then
            NotifyConfig("File API unavailable", true)
            return false
        end
        if not enabled or cleanName == "" then
            pcall(function() writefile(AutoLoadFile, HttpService:JSONEncode({Name = ""})) end)
            NotifyConfig("Auto load cleared")
            return true
        end
        local ok = pcall(function()
            writefile(AutoLoadFile, HttpService:JSONEncode({Name = cleanName}))
        end)
        if ok then
            NotifyConfig("Auto load set to '" .. cleanName .. "'")
            return true
        end
        NotifyConfig("Failed to set auto load", true)
        return false
    end

    local function GetAutoLoad()
        if not HasFileApi() or not isfile(AutoLoadFile) then return "" end
        local ok, decoded = pcall(function()
            return HttpService:JSONDecode(readfile(AutoLoadFile))
        end)
