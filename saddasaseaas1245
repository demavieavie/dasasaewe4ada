    -- Fuzzy search function
    local function fuzzyMatch(query, text)
        query = string.lower(query)
        text = string.lower(text)

        -- Exact match
        if string.find(text, query, 1, true) then
            return true, string.find(text, query, 1, true)
        end

        -- Fuzzy: check if all chars exist in order
        local queryIdx = 1
        for i = 1, #text do
            if queryIdx <= #query and string.sub(text, i, i) == string.sub(query, queryIdx, queryIdx) then
                queryIdx = queryIdx + 1
            end
        end

        return queryIdx > #query, -1
    end

    -- Tab storage for search
