                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 5),
                    Size = UDim2.new(1, -180, 0, 13),
                    Name = "DropdownTitle",
                }, Dropdown)

                local DropdownContent = Custom:Create("TextLabel", {
                    Font = Custom.FontBody,
                    Text = Content,
                    TextColor3 = Colors.TextDesc,
                    TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextYAlignment = Enum.TextYAlignment.Bottom,
                    TextWrapped = true,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 17),
                    Size = UDim2.new(1, -180, 0, 10),
                    Name = "DropdownContent",
                }, Dropdown)

                DropdownContent:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
                    local newHeight = math.max(34, DropdownContent.AbsoluteSize.Y + 22)
                    Dropdown.Size = UDim2.new(1, 0, 0, newHeight)
                    UpdateSizeSection()
                end)

                -- Dropdown selector
                local SelectOptionsFrame = Custom:Create("Frame", {
                    AnchorPoint = Vector2.new(1, 0.5),
                    BackgroundColor3 = Colors.DropdownBg,
                    Position = UDim2.new(1, -10, 0.5, 0),
                    Size = UDim2.new(0, 148, 0, 24),
                    Name = "SelectOptionsFrame",
                }, Dropdown)

                Custom:Create("UICorner", {CornerRadius = UDim.new(0, 4)}, SelectOptionsFrame)
                Custom:Create("UIStroke", {Color = Colors.BorderSubtle, Thickness = 1, Transparency = 0.3}, SelectOptionsFrame)

                local OptionSelecting = Custom:Create("TextLabel", {
                    Font = Custom.Font,
                    Text = "Select...",
                    TextColor3 = Colors.TextMuted,
                    TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    AnchorPoint = Vector2.new(0, 0.5),
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 8, 0.5, 0),
                    Size = UDim2.new(1, -30, 1, 0),
                    Name = "OptionSelecting",
                }, SelectOptionsFrame)

                local OptionImg = Custom:Create("ImageLabel", {
                    Image = "rbxassetid://90200523188815",
                    BackgroundTransparency = 1,
                    AnchorPoint = Vector2.new(1, 0.5),
                    Position = UDim2.new(1, -5, 0.5, 0),
                    Size = UDim2.new(0, 16, 0, 16),
                    Name = "OptionImg",
                }, SelectOptionsFrame)

                -- Options popup - Fixed styling to match UI theme
                local DropdownPopup = nil
                local popupOpen = false
                local closeConn = nil

                local function CloseDropdownPopup()
                    popupOpen = false
                    if closeConn then
                        closeConn:Disconnect()
                        closeConn = nil
                    end
                    if DropdownPopup then
                        DropdownPopup:Destroy()
                        DropdownPopup = nil
                    end
                end

                local function CreateDropdownPopup()
                    CloseDropdownPopup()

                    popupOpen = true
                    DropdownPopup = Custom:Create("Frame", {
                        BackgroundColor3 = Colors.DropdownBg,  -- Dark purple-black
                        Position = UDim2.new(0, 0, 1, 4),
                        Size = UDim2.new(1, 0, 0, 0),
                        ClipsDescendants = true,
                        ZIndex = 100,
                        Name = "DropdownPopup"
                    }, SelectOptionsFrame)

                    Custom:Create("UICorner", {CornerRadius = UDim.new(0, 6)}, DropdownPopup)
                    -- Subtle purple/gray border, not bright
                    Custom:Create("UIStroke", {Color = Colors.BorderHighlight, Thickness = 1, Transparency = 0.5}, DropdownPopup)

                    local popupScroll = Custom:Create("ScrollingFrame", {
                        CanvasSize = UDim2.new(0, 0, 0, 0),
                        ScrollBarImageColor3 = Custom.ColorRGB,
                        ScrollBarThickness = 2,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 1, 0),
                        Name = "PopupScroll"
                    }, DropdownPopup)

                    Custom:Create("UIListLayout", {
                        Padding = UDim.new(0, 2),
                        SortOrder = Enum.SortOrder.LayoutOrder
                    }, popupScroll)

                    local totalHeight = 0
                    local itemHeight = 26  -- Compact item height
                    for _, optName in ipairs(Funcs_Dropdown.Options) do
                        local isSelected = table.find(Funcs_Dropdown.Value, optName) ~= nil

                        local optBtn = Custom:Create("Frame", {
                            BackgroundColor3 = isSelected and Colors.RowBgSelected or Colors.DropdownOption,
                            Size = UDim2.new(1, 0, 0, itemHeight),
                            Name = "Option"
                        }, popupScroll)

                        Custom:Create("UICorner", {CornerRadius = UDim.new(0, 4)}, optBtn)

                        if isSelected then
                            local checkmark = Custom:Create("Frame", {
                                AnchorPoint = Vector2.new(0, 0.5),
                                BackgroundColor3 = Custom.ColorRGB,
                                Position = UDim2.new(0, 4, 0.5, 0),
                                Size = UDim2.new(0, 4, 0, 12),
                                Name = "Checkmark"
                            }, optBtn)
                            Custom:Create("UICorner", {}, checkmark)
                        end

                        Custom:Create("TextLabel", {
                            Font = Custom.Font,
                            Text = optName,
                            TextColor3 = isSelected and Colors.TextTitle or Colors.TextDesc,
                            TextSize = 12,
                            TextXAlignment = Enum.TextXAlignment.Left,
                            BackgroundTransparency = 1,
                            Position = UDim2.new(0, isSelected and 14 or 8, 0, 0),
                            Size = UDim2.new(1, -16, 1, 0),
                            Name = "OptionText"
                        }, optBtn)

                        optBtn.InputBegan:Connect(function(input)
                            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                                CircleClick(optBtn, Player:GetMouse().X, Player:GetMouse().Y)

                                if Multi then
                                    if isSelected then
                                        for i, v in ipairs(Funcs_Dropdown.Value) do
                                            if v == optName then table.remove(Funcs_Dropdown.Value, i) break end
                                        end
                                    else
                                        table.insert(Funcs_Dropdown.Value, optName)
                                    end
                                else
                                    Funcs_Dropdown.Value = {optName}
                                end

                                Funcs_Dropdown:Set(Funcs_Dropdown.Value)
                                if Multi then
                                    CreateDropdownPopup()
                                else
                                    CloseDropdownPopup()
                                end
                            end
                        end)

                        totalHeight = totalHeight + itemHeight + 2
                    end

                    popupScroll.CanvasSize = UDim2.new(0, 0, 0, totalHeight)

                    local desiredHeight = math.min(totalHeight, 128)
                    local mainTop = Main.AbsolutePosition.Y + 8
                    local mainBottom = Main.AbsolutePosition.Y + Main.AbsoluteSize.Y - 8
                    local belowY = SelectOptionsFrame.AbsolutePosition.Y + SelectOptionsFrame.AbsoluteSize.Y + 4
                    local belowSpace = mainBottom - belowY
                    local aboveSpace = SelectOptionsFrame.AbsolutePosition.Y - mainTop - 4
                    local openUp = belowSpace < desiredHeight and aboveSpace > belowSpace
                    local popupHeight = math.max(34, math.min(desiredHeight, openUp and aboveSpace or belowSpace))

                    DropdownPopup.AnchorPoint = openUp and Vector2.new(0, 1) or Vector2.new(0, 0)
                    DropdownPopup.Position = openUp and UDim2.new(0, 0, 0, -4) or UDim2.new(0, 0, 1, 4)
                    DropdownPopup.Size = UDim2.new(1, 0, 0, popupHeight)

                    -- Click outside to close
                    closeConn = UserInputService.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            local mouse = Player:GetMouse()
                            local x, y = mouse.X, mouse.Y
                            local popupPos = DropdownPopup.AbsolutePosition
                            local popupSize = DropdownPopup.AbsoluteSize
                            local fieldPos = SelectOptionsFrame.AbsolutePosition
                            local fieldSize = SelectOptionsFrame.AbsoluteSize
                            local inPopup = x >= popupPos.X and x <= popupPos.X + popupSize.X and y >= popupPos.Y and y <= popupPos.Y + popupSize.Y
                            local inField = x >= fieldPos.X and x <= fieldPos.X + fieldSize.X and y >= fieldPos.Y and y <= fieldPos.Y + fieldSize.Y
                            if not inPopup and not inField then
                                CloseDropdownPopup()
                            end
                        end
                    end)
                end

                DropdownButton.Activated:Connect(function()
                    CircleClick(DropdownButton, Player:GetMouse().X, Player:GetMouse().Y)
                    if popupOpen then
                        CloseDropdownPopup()
                    else
                        CreateDropdownPopup()
                    end
                end)

                function Funcs_Dropdown:Set(Value)
                    Funcs_Dropdown.Value = NormalizeDropdownValue(Value or Funcs_Dropdown.Value)
                    local displayText = table.concat(Funcs_Dropdown.Value, ", ")
                    OptionSelecting.Text = displayText ~= "" and displayText or "Select..."
                    OptionSelecting.TextColor3 = displayText ~= "" and Colors.TextTitle or Colors.TextMuted
                    Callback(Multi and Funcs_Dropdown.Value or Funcs_Dropdown.Value[1])
                end

                function Funcs_Dropdown:Get()
                    return Multi and Funcs_Dropdown.Value or Funcs_Dropdown.Value[1]
                end

                function Funcs_Dropdown:Refresh(RefreshList, Selecting)
                    RefreshList = RefreshList or {}
                    Selecting = NormalizeDropdownValue(Selecting)
                    Funcs_Dropdown.Options = RefreshList
                    Funcs_Dropdown.Value = Selecting
                    Funcs_Dropdown:Set(Funcs_Dropdown.Value)
                end

                function Funcs_Dropdown:SetValues(RefreshList, Selecting)
                    return Funcs_Dropdown:Refresh(RefreshList, Selecting)
                end

                Funcs_Dropdown:Refresh(Funcs_Dropdown.Options, Funcs_Dropdown.Value)
                RegisterConfigElement("Dropdown", Title, Config, Funcs_Dropdown)
                ItemCount = ItemCount + 1
                return Funcs_Dropdown
            end

            function Item:AddConfigPanel(Config)
                Config = Config or {}

                local selectedConfig = Config.Default or Config.Selected or GetAutoLoad()
                local currentName = selectedConfig or ""
                local getSaved = Config.GetSaved or Config.GetConfigs or function()
                    return Config.Saved or Config.Options or GetConfigs()
                end

                local function ResolveName(NameInput)
                    local live = NameInput and NameInput.Get and NameInput:Get() or currentName
                    live = tostring(live or ""):gsub("^%s+", ""):gsub("%s+$", "")
                    if live ~= "" then currentName = live end
                    return live
                end

                local NameInput = Item:AddInput({
                    Title = Config.NameTitle or "Config Name",
                    Content = Config.NameContent or "Name for saving",
                    Placeholder = Config.Placeholder or "MyConfig",
                    Default = currentName,
                    NoConfig = true,
                    Callback = function(text)
                        currentName = text
                    end
                })

                local ConfigList
                local function RefreshList(selecting)
                    local list = getSaved() or {}
                    if ConfigList and ConfigList.Refresh then
                        ConfigList:Refresh(list, selecting or selectedConfig)
                    end
                    return list
                end

                ConfigList = Item:AddDropdown({
                    Title = Config.ListTitle or "Saved Configs",
                    Content = Config.ListContent or "Select saved config",
                    Multi = false,
                    Options = getSaved() or {},
                    Default = selectedConfig,
                    NoConfig = true,
                    Callback = function(choice)
                        selectedConfig = choice
                        if choice and choice ~= "" then
                            currentName = choice
                            if NameInput and NameInput.Set then
                                NameInput:Set(choice)
                            end
                        end
                    end
                })

                local function NeedName()
                    NotifyConfig("Enter a config name first", true)
                    return false
                end

                local function DoAutoLoad()
                    local name = selectedConfig
                    if not name or name == "" then
                        name = ResolveName(NameInput)
                    end
                    if not name or name == "" then return NeedName() end

                    if Config.OnAutoLoad or Config.AutoLoad then
                        local fn = Config.OnAutoLoad or Config.AutoLoad
                        local result = fn(name)
                        if result ~= false then
                            selectedConfig = name
                            currentName = name
                            RefreshList(name)
                        end
                        return result
                    end
                    if not ReadConfigPayload(name) then
                        NotifyConfig("Config not found, use Save as Auto Load first", true)
                        return false
                    end
                    local ok = SetAutoLoad(name, true)
                    if ok then
                        selectedConfig = name
                        currentName = name
                        RefreshList(name)
                    end
                    return ok
                end

                local function DoSaveAsAutoLoad()
                    local name = ResolveName(NameInput)
                    if name == "" then
                        name = selectedConfig or ""
                    end
                    if name == "" then return NeedName() end

                    if Config.OnSaveAsAutoLoad or Config.SaveAsAutoLoad or Config.SaveAutoLoad then
                        local fn = Config.OnSaveAsAutoLoad or Config.SaveAsAutoLoad or Config.SaveAutoLoad
                        local result = fn(name)
                        if result ~= false then
                            selectedConfig = type(result) == "string" and result or name
                            currentName = selectedConfig
                            if NameInput and NameInput.Set then
                                NameInput:Set(selectedConfig)
                            end
                            RefreshList(selectedConfig)
                        end
                        return result
                    end

                    local ok, savedName = SaveConfigAs(name)
                    if ok then
                        selectedConfig = savedName or name
                        currentName = selectedConfig
                        SetAutoLoad(selectedConfig, true)
                        if NameInput and NameInput.Set then
                            NameInput:Set(selectedConfig)
                        end
                        RefreshList(selectedConfig)
                    end
                    return ok
                end

                Item:AddButton({
                    Title = Config.AutoLoadText or "Auto Load",
                    Content = "",
                    Icon = "",
                    Centered = true,
                    NoConfig = true,
                    Callback = DoAutoLoad
                })

                Item:AddButton({
                    Title = Config.SaveAutoLoadText or "Save as Auto Load",
                    Content = "",
                    Icon = "",
                    Centered = true,
                    NoConfig = true,
                    Callback = DoSaveAsAutoLoad
                })

                local ConfigPanel = {}

                function ConfigPanel:Refresh(selecting)
                    return RefreshList(selecting)
                end

                function ConfigPanel:GetName()
                    return ResolveName(NameInput)
                end

                function ConfigPanel:GetSelected()
                    return selectedConfig
                end

                function ConfigPanel:SetName(name)
                    currentName = tostring(name or "")
                    selectedConfig = currentName
                    if NameInput and NameInput.Set then
                        NameInput:Set(currentName)
                    end
                    RefreshList(currentName)
                end

                return ConfigPanel
            end

            function Item:AddConfig(Config)
                return self:AddConfigPanel(Config)
            end

            ItemCount = ItemCount + 1
            return Item
        end

        CountTab = CountTab + 1
        return Sections
    end

    function Tabs:GetConfigs()
        return GetConfigs()
    end

    function Tabs:SaveConfigAs(name)
        return SaveConfigAs(name)
    end

    function Tabs:LoadConfigByName(name)
        return LoadConfigByName(name)
    end

    function Tabs:SetAutoLoad(name, enabled)
        return SetAutoLoad(name, enabled)
    end

    function Tabs:GetAutoLoad()
        return GetAutoLoad()
    end

    function Tabs:LoadAutoLoad()
        local autoName = GetAutoLoad()
        if autoName and autoName ~= "" then
            return LoadConfigByName(autoName)
        end
        return false
    end

    if Config.AutoLoad ~= false then
        task.spawn(function()
            task.wait(0.5)
            Tabs:LoadAutoLoad()
        end)
    end

    return Tabs
end

return WisHub_Library
