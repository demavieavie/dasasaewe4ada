local function ResolveAsset(asset)
    if asset == nil then return "" end
    asset = tostring(asset)
    if asset == "" then return "" end
    if Icons[string.lower(asset)] then return Icons[string.lower(asset)] end
    if tonumber(asset) then return "rbxassetid://" .. asset end
    return asset
end

local function NormalizeTabName(tabName)
    local text = tostring(tabName or "")
    text = text:gsub("%[", ""):gsub("%]", "")
    text = text:gsub("^%s+", ""):gsub("%s+$", "")
    return string.lower(text)
end

local function ResolveTabIcon(tabName, explicitIcon)
    local icon = ResolveAsset(explicitIcon)
    if icon ~= "" then return icon end
    local iconKey = DefaultTabIcons[NormalizeTabName(tabName)]
    return iconKey and ResolveAsset(iconKey) or ""
end

function Custom:Create(Name, Properties, Parent)
    local _instance = Instance.new(Name)
    for i, v in pairs(Properties) do
        _instance[i] = v
    end
    if Parent then _instance.Parent = Parent end
    return _instance
end

