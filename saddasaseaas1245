-- Debounce utility
local function Debounce(func, delay)
    local lastCall = 0
    return function(...)
        local current = tick()
        if current - lastCall >= delay then
            lastCall = current
            return func(...)
        end
    end
end

local function OpenClose()
    local GuiParent = RunService:IsStudio() and Player.PlayerGui or (gethui() or cloneref(game:GetService("CoreGui")) or game:GetService("CoreGui"))
    local OldToggleGui = GuiParent:FindFirstChild(Custom.ToggleGuiName)
